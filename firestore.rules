rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Monsters collection (global, read-only for authenticated users)
    match /monsters/{monsterId} {
      allow read: if request.auth != null;
    }

    // User-scoped data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /encounters/{encounterId} {
        // Owner can read/write their own encounters
        allow read, write: if request.auth != null && request.auth.uid == userId;

        // Anyone can read an encounter if it has a valid share link
        // (looked up via the shared_encounters collection)
        allow read: if exists(/databases/$(database)/documents/shared_encounters/$(resource.data.shareId));

        match /npcs/{npcId} {
          // Owner can read/write NPCs in their encounters
          allow read, write: if request.auth != null && request.auth.uid == userId;

          // Anyone can read NPCs if they have a valid shareId (denormalized from encounter)
          allow read: if exists(/databases/$(database)/documents/shared_encounters/$(resource.data.shareId));
        }
      }
    }

    // Shared encounter lookup documents (public read, owner write)
    match /shared_encounters/{shareId} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.ownerUid == request.auth.uid;
    }
  }
}
